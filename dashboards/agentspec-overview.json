{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Invocation Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(agentspec_invocations_total[5m])",
          "legendFormat": "{{agent}} ({{status}})"
        }
      ]
    },
    {
      "title": "Latency Percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(agentspec_invocation_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(agentspec_invocation_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(agentspec_invocation_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Token Consumption",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(agentspec_tokens_total{direction=\"input\"}[5m])",
          "legendFormat": "{{agent}} input"
        },
        {
          "expr": "rate(agentspec_tokens_total{direction=\"output\"}[5m])",
          "legendFormat": "{{agent}} output"
        }
      ]
    },
    {
      "title": "Cost Tracking ($)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "agentspec_cost_dollars_total",
          "legendFormat": "{{agent}} ({{model}})"
        }
      ]
    },
    {
      "title": "Tool Call Patterns",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(agentspec_tool_calls_total[5m])",
          "legendFormat": "{{agent}}/{{tool}} ({{status}})"
        }
      ]
    },
    {
      "title": "Fallback Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(agentspec_fallback_total[5m])",
          "legendFormat": "{{agent}} → {{to_model}}"
        }
      ]
    },
    {
      "title": "Guardrail Violations",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "agentspec_guardrail_violations_total",
          "legendFormat": "{{agent}} ({{mode}})"
        }
      ]
    },
    {
      "title": "Budget Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "agentspec_budget_usage_ratio",
          "legendFormat": "{{agent}} ({{period}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["agentspec"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "AgentSpec Overview",
  "uid": "agentspec-overview"
}
